{
  "expo": {
    "name": "SujudApp",
    "slug": "SujudApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abuabz.SujudApp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1F12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.abuabz.SujudApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sujud to access your location to calculate accurate prayer times."
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0B1F12"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "19012b68-b26d-4a6b-92e8-afabe88ef256"
      }
    }
  }
}
